VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJxxx...
VITE_SUPABASE_PROJECT_ID=xxxxx
VITE_GOOGLE_OAUTH_ENABLED=false
# Set to true only after configuring Google provider:
# 1. Go to console.cloud.google.com → Create OAuth 2.0 credentials
# 2. Add redirect URI: https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 3. In Supabase Dashboard → Authentication → Providers → Google → Enable
# 4. Paste Client ID and Secret
# 5. Set VITE_GOOGLE_OAUTH_ENABLED=true
